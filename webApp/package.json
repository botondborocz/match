{
  "name": "match",
  "version": "1.0.0",
  "description": "Web application that uses Kotlin Multiplatform Library",
  "type": "module",
  "scripts": {
    "sync-i18n": "tsx scripts/sync-i18n.ts",
    "sync-theme": "node scripts/syncTheme.ts",
    "build": "npm run sync-i18n && npm run sync-theme && tsc && vite build",
    "start": "npm run sync-i18n && npm run sync-theme && vite --host"
  },
  "dependencies": {
    "glob": "^13.0.5",
    "i18next": "^25.8.11",
    "lucide-react": "^0.568.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "shared": "0.0.0-unspecified"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.2",
    "vite": "^7.1.6",
    "xml2js": "^0.6.2"
  }
}
